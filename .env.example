# IServ-Zugangsdaten (Ausleihe-Admin-Account, Lukas — NUR LESEND).
# Echte Werte in .env eintragen — .env ist gitignored und darf NIE committet werden.
ISERV_DOMAIN=iserv-trg-oha.de
ISERV_USERNAME=
ISERV_PASSWORD=

# Host-Zugang (lokales Passwort für die Host-UI)
HOST_PASSWORD=

# Server-Konfiguration (optional, Defaults wie angegeben)
PORT=3443
WORKER_CONTEXTS=2
# HOST_IP=192.168.x.x       # LAN-IP für QR-/Join-URLs erzwingen. Nur nötig, wenn
#                           # der Laptop mehrere Interfaces hat (WLAN + VPN/Docker)
#                           # und die Auto-Erkennung das falsche Netz wählt.
# HOST_SESSION_TTL_S=43200  # Host-Login-Timeout in Sekunden (Default 12 h, gleitend)

# Playwright-Debug (optional). Nur auf Rechnern mit Display (nicht headless-VPS).
# HEADLESS=false    # Browserfenster sichtbar machen (Default true = unsichtbar)
# SLOW_MO_MS=300    # verlangsamt jede Playwright-Aktion um X ms (Default 0)

# Leihschein-Druck (optional). PRINT_BACKEND:
#   auto  (Default) Windows->SumatraPDF, macOS->lp (CUPS), sonst->file
#   file  PDF nur speichern (automation/out/loan_slips/), nicht drucken
#   lp    CUPS lp (macOS/Linux, USB-Drucker)
#   sumatra      SumatraPDF Silent-Print (Windows)
#   win-default  Windows-Fallback ohne SumatraPDF (os.startfile print)
PRINT_BACKEND=auto
# PRINTER_NAME=         # leer = Standarddrucker
# SUMATRA_PATH=         # nur falls SumatraPDF nicht im PATH/Standardpfad liegt

# !!! BUCHUNG GEGEN DIE IServ-PRODUKTION !!!
# false (Default) = der buchende Submit-Pfad ist gesperrt (Scan bleibt staged,
# kein Enter). NUR im freigegebenen Buchungstest auf true setzen — nach
# expliziter Freigabe von Niklas UND Lukas, mit ausgemustertem Buch + Rückbau-Plan
# (CLAUDE.md / PLAN §6). Im Normalbetrieb IMMER false lassen.
ALLOW_BOOKING=false
